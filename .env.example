# Pins the Server Actions encryption key across builds/deploys. Without this,
# Next.js generates a new random key on every build, so any page a visitor has
# open from before a redeploy fails with "Server action not found" on submit.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Google Tag Manager container ID (not secret, but kept as an env var since it
# may differ between environments). If unset, the GTM script/noscript tags
# are simply omitted.
NEXT_PUBLIC_GTM_ID=

# Google Sheets lead storage (used by src/ai/flows/save-enquiry-flow.ts via src/config/site.ts)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep the \n escape sequences literal (do not replace with real newlines) — the app un-escapes them at runtime.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Enquiry notification email (SMTP) — optional; sending is skipped if any of these are blank
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
ENQUIRY_NOTIFICATION_EMAIL=prashant.k@digitalbuzz.co.in
